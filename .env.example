# ============================================================================
# Virgil environment variables
#
# Sections are grouped by feature tier. Tier 0 is required for `pnpm dev`.
# Everything below is additive — enable the features you use.
#
# One-command setup: `pnpm virgil:env:init` copies this file into .env.local
# (and appends any keys missing from your existing .env.local, as comments).
# Run `pnpm virgil:status` at any time to see which features are configured,
# missing, or offline — with concrete fix hints.
# ============================================================================


# =====================================================
# Tier 0 — Core (required for `pnpm dev` + any deploy)
# =====================================================

# Session/JWT secret. Generate: openssl rand -base64 32
# Dev uses an insecure fallback if unset; production / `next build` / `next start` need this.
AUTH_SECRET=****

# Browser origin users actually open (scheme + host + port, no path). NextAuth cookies require an exact match.
# Local: http://localhost:3000  |  LAN: http://192.168.x.x:3000  |  Vercel: https://your-project.vercel.app
AUTH_URL=
NEXT_PUBLIC_APP_URL=

# Postgres connection string — Neon, Supabase, or any standard Postgres.
# Neon: https://console.neon.tech (pooled/serverless string for Vercel)
# Supabase: transaction pooler (port 6543) for runtime; direct (5432) for `pnpm db:migrate` DDL if needed.
POSTGRES_URL=****

# Redis for rate limits (Upstash free tier OK). https://vercel.com/docs/redis
REDIS_URL=****

# File uploads via Vercel Blob. https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# AI Gateway (required for hosted models locally; Vercel uses OIDC automatically).
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****


# =====================================================
# Tier 1 — Delegation (Virgil → Hermes → OpenClaw)
# =====================================================
#
# The Hermes bridge runs IN the Next.js app at /api/hermes-bridge/* — no
# separate process needed. Leave HERMES_HTTP_URL unset to use it.
#
# To forward delegations to an OpenClaw Gateway on your LAN, set
# OPENCLAW_HTTP_URL + OPENCLAW_GATEWAY_TOKEN below. `pnpm virgil:start` will
# auto-spawn the SSH tunnel if OPENCLAW_SSH_HOST is set.
#
# --- Full tool access (Hermes in-app bridge + OpenClaw gateway) ---------------
# Virgil does not enumerate every OpenClaw tool name; the gateway enforces policy.
# 1) Leave HERMES_HTTP_URL unset (in-app bridge → same process as Next.js). If you
#    use a remote Hermes URL instead, that server must forward to an OpenClaw with
#    the same tool policy you expect (Virgil only sees Hermes’ advertised skills).
# 2) Point OPENCLAW_HTTP_URL at the tunnel (e.g. http://127.0.0.1:18789).
# 3) OPENCLAW_EXECUTE_PATH=/tools/invoke + OPENCLAW_GATEWAY_TOKEN (or PASSWORD).
# 4) Do NOT set VIRGIL_DELEGATION_STRICT_SKILLS=1 unless you want in-app rejection.
# 5) Do NOT set OPENCLAW_SINGLE_TOOL_MODE=1 unless you want all tasks via one tool.
# 6) On the OpenClaw host, relax gateway.tools allow/deny so HTTP /tools/invoke
#    can reach the tools you need: https://docs.openclaw.ai/gateway/tools-invoke-http-api.md
# 7) Optional: OPENCLAW_SKILLS_STATIC=comma,tools for health/UI skill counts when
#    GET /api/skills returns 404.
# -----------------------------------------------------------------------------

# OpenClaw Gateway (LAN execution target). Use http/https or ws/wss (ws auto-upcast to http).
# OPENCLAW_URL=ws://127.0.0.1:13100
# OPENCLAW_HTTP_URL=http://127.0.0.1:18789
# OPENCLAW_EXECUTE_PATH=/tools/invoke
# OPENCLAW_GATEWAY_TOOLS_INVOKE=1
# OPENCLAW_GATEWAY_TOKEN=       # Bearer; matches gateway.auth.token (mode: token)
# OPENCLAW_GATEWAY_PASSWORD=    # Bearer; matches gateway.auth.password (mode: password)

# Default OpenClaw tool for skill id "generic-task" (and when single-tool mode is on).
# OPENCLAW_GENERIC_TASK_TOOL=web
# Single-tool mode: route every delegation through GENERIC_TASK_TOOL with args.virgilSkill.
# Default is OFF — Virgil skill names map 1:1 to OpenClaw tool names (use any tool the gateway allows).
# OPENCLAW_SINGLE_TOOL_MODE=1
# OPENCLAW_SKILLS_PATH=/api/skills
# Gateway-only: GET /api/skills often 404 — list tool ids for health/embed matching:
# OPENCLAW_SKILLS_STATIC=web,wiki-embed,read,generic-task
# OPENCLAW_HEALTH_PATH=/health

# Strict skill allowlist for delegateTask (default off; gateway decides which
# skills exist). Set to 1 to reject unknown skill names in-app.
# VIRGIL_DELEGATION_STRICT_SKILLS=1

# Selects delegation provider path. Default: prefer Hermes when configured, else OpenClaw.
# VIRGIL_DELEGATION_BACKEND=hermes

# Point Virgil at an EXTERNAL Hermes instead of the in-app bridge (rare; e.g.
# routing delegations into a separate service on another host).
# HERMES_HTTP_URL=https://hermes.your-domain.example
# HERMES_SHARED_SECRET=<matches the Hermes deployment>

# When BOTH Hermes and OpenClaw are configured, failover is on by default.
# VIRGIL_DELEGATION_FAILOVER=1

# --- Shape A: poll worker (Vercel → Mac drains queue; no inbound tunnels) ---
# On Vercel: set POLL_PRIMARY=1 + WORKER_SECRET. On the Mac: set WORKER_BASE_URL
# + same WORKER_SECRET, then run `pnpm virgil:start` (auto-spawns the worker).
# VIRGIL_DELEGATION_POLL_PRIMARY=1
# VIRGIL_DELEGATION_WORKER_SECRET=<openssl rand -base64 32>
# VIRGIL_DELEGATION_WORKER_BASE_URL=https://your-deployment.vercel.app
# VIRGIL_DELEGATION_POLL_WAIT_MS=0
# VIRGIL_DELEGATION_POLL_INTERVAL_MS=5000
# VIRGIL_DELEGATION_WORKER_EXECUTE_TIMEOUT_MS=120000

# Synchronous embeddings via delegation (embedViaDelegation chat tool).
# VIRGIL_DELEGATION_EMBED_SKILL=wiki-embed
# VIRGIL_DELEGATION_EMBED_TIMEOUT_MS=30000
# VIRGIL_DELEGATION_EMBED_ENABLED=1

# --- Auto SSH tunnel via `pnpm virgil:start` ---
# When set, `pnpm virgil:start` spawns scripts/openclaw-tunnel.sh alongside
# `next dev`. LOCAL/REMOTE ports must match the OpenClaw Gateway port (same
# number on both ends of the tunnel). Default Gateway build listens on 18789.
# OPENCLAW_SSH_HOST=user@192.168.1.81
# OPENCLAW_LOCAL_PORT=18789
# OPENCLAW_REMOTE_PORT=18789

# Protects `/api/digest` and `/api/night-review/enqueue`. Generate: openssl rand -base64 32
# CRON_SECRET=


# =====================================================
# Tier 2 — Reminders, email, and inbound channels
# =====================================================

# QStash (Upstash Console → QStash → Details) — reminders, night review, agent-task triage.
# SDK defaults to EU region; US tokens must set QSTASH_URL explicitly.
# QSTASH_TOKEN=ey…
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=
# QSTASH_URL=https://qstash-us-east-1.upstash.io

# Resend (outbound reminders + digest + webhook signing for inbound email).
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=

# Inbound email → Memory (Resend receiving + verified domain)
# VIRGIL_EMAIL_INGEST_ENABLED=1
# VIRGIL_EMAIL_INGEST_ALLOWED_FROM=you@yourdomain.example

# Apple Watch / HealthKit native companion ingest
# VIRGIL_HEALTH_INGEST_ENABLED=1
# VIRGIL_HEALTH_INGEST_SECRET=
# VIRGIL_HEALTH_INGEST_USER_ID=

# General scripts/shortcuts ingest (Bearer → fixed user id)
# VIRGIL_INGEST_ENABLED=1
# VIRGIL_INGEST_SECRET=
# VIRGIL_INGEST_USER_ID=

# Memory bridge for terminal scripts (search + save Memory via HTTP)
# VIRGIL_MEMORY_BRIDGE_ENABLED=1
# VIRGIL_MEMORY_BRIDGE_SECRET=
# VIRGIL_MEMORY_BRIDGE_USER_ID=
# VIRGIL_MEMORY_BRIDGE_BASE_URL=https://your-deployment.vercel.app

# Alexa single-owner voice ingress
# VIRGIL_ALEXA_ENABLED=1
# VIRGIL_ALEXA_SECRET=
# VIRGIL_ALEXA_USER_ID=

# Slack digest mirror (webhook OR bot token + channel)
# VIRGIL_SLACK_CHECKIN_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_BOT_TOKEN=xoxb-...
# VIRGIL_SLACK_CHECKIN_CHANNEL_ID=C01234567890


# =====================================================
# Tier 3 — Third-party integrations (optional)
# =====================================================

# Google Calendar — read-only (see docs/google-calendar-integration.md)
# VIRGIL_CALENDAR_INTEGRATION=1
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=

# Mem0 Cloud semantic memory (falls back to Postgres FTS when missing)
# MEM0_API_KEY=
# MEM0_MONTHLY_SEARCH_LIMIT=1000
# MEM0_MONTHLY_ADD_LIMIT=2000
# MEM0_DISABLE_LOCAL_SYNC=1

# GitHub product-opportunity issues (gateway models only)
# GITHUB_REPOSITORY=owner/virgil-repo
# GITHUB_PRODUCT_OPPORTUNITY_TOKEN=ghp_****
# GITHUB_PRODUCT_OPPORTUNITY_LABELS=product-opportunity,needs-owner-decision

# Jira Cloud
# JIRA_BASE_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# Direct Gemini key (chat fallback only; night review uses local Ollama)
# GOOGLE_GENERATIVE_AI_API_KEY=

# Digital Self orchestrator (sibling package; optional)
# DIGITAL_SELF_BASE_URL=http://127.0.0.1:8790
# DIGITAL_SELF_SERVICE_TOKEN=
# VIRGIL_BRIDGE_WEBHOOK_SECRET=


# =====================================================
# Tier 4 — Models, Ollama, fallback chains
# =====================================================

# Host or LAN Ollama inference server (picker + optional fallback).
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# WARMUP_MODEL=ollama/qwen2.5:3b

# Default chat model for the picker and new chats.
# NEXT_PUBLIC_DEFAULT_CHAT_MODEL=google/gemini-2.5-flash-lite
# DEFAULT_CHAT_MODEL=openai/gpt-oss-20b

# Chat fallback chain: Ollama → Gemini → Gateway
# VIRGIL_CHAT_FALLBACK=1
# VIRGIL_FALLBACK_GEMINI_MODEL=gemini-2.5-flash
# VIRGIL_FALLBACK_GATEWAY_MODEL=google/gemini-2.5-flash-lite

# Gateway fallback: hosted → direct Gemini → Ollama
# VIRGIL_GATEWAY_FALLBACK_GEMINI_MODEL=gemini-2.5-flash-lite
# VIRGIL_GATEWAY_FALLBACK_OLLAMA=1
# DEFAULT_GATEWAY_FALLBACK_OLLAMA_MODEL=ollama/qwen2.5:7b-instruct

# virgil/auto picker (local vs lite hosted)
# VIRGIL_AUTO_LOCAL_MODEL=ollama/qwen2.5:3b
# VIRGIL_AUTO_HOSTED_FALLBACK_MODEL=google/gemini-2.5-flash-lite

# Ollama embeddings for Memory (pgvector; uses OLLAMA_BASE_URL)
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768

# Memories surfaced in the system prompt
# MEMORY_PROMPT_WINDOW_DAYS=30
# MEMORY_PROMPT_FETCH_LIMIT=80


# =====================================================
# Tier 5 — Scheduled jobs (night review, wiki ops, journal)
# =====================================================

# Night review (Vercel prod: on by default; local/preview: set =1)
# NIGHT_REVIEW_ENABLED=1
# NIGHT_REVIEW_MODEL=ollama/qwen2.5:7b-review
# NIGHT_REVIEW_STAGGER_SECONDS=60
# NIGHT_REVIEW_TIMEZONE=America/New_York
# NIGHT_REVIEW_OFF_PEAK_START_HOUR=23
# NIGHT_REVIEW_OFF_PEAK_END_HOUR=7
# NIGHT_REVIEW_RUN_LOCAL_HOUR=23
# NIGHT_REVIEW_EMAIL_ON_FINDINGS=1
# AGENT_FETCH_ALLOWLIST_HOSTS=geocoding-api.open-meteo.com,api.open-meteo.com

# Wiki ops (manual admin trigger)
# VIRGIL_WIKI_OPS_ENABLED=1
# VIRGIL_WIKI_ROOT=workspace/wiki-starter
# VIRGIL_WIKI_DAILY_ENABLED=1

# Journal file parse
# VIRGIL_JOURNAL_FILE_PARSE=1
# VIRGIL_JOURNAL_FILE_PATH=workspace/journal/today.md

# Override user context markdown path
# USER_CONTEXT_PATH=workspace/user-context.md


# =====================================================
# Tier 6 — Feature flags
# =====================================================

# Passwordless email-only sign-in for allowlisted addresses (trusted setups)
# VIRGIL_PASSWORDLESS_LOGIN=1
# VIRGIL_PASSWORDLESS_EMAILS=you@example.com

# Temporary guest sessions (no account) from login/register — off by default
# VIRGIL_GUEST_LOGIN_ENABLED=1

# Web Speech TTS on assistant messages
# NEXT_PUBLIC_VIRGIL_TTS_ENABLED=1

# Agent task triage (background Ollama job)
# AGENT_TASK_TRIAGE_ENABLED=1
# AGENT_TASK_TRIAGE_MODEL=ollama/qwen2.5:7b-instruct

# Gateway-only planner pass before main reply (extra cost/latency)
# VIRGIL_MULTI_AGENT_ENABLED=1
# VIRGIL_MULTI_AGENT_PLANNER_MODEL=openai/gpt-4o-mini
# Optional: sequential planner passes (amount) and per-stage output caps (size):
# VIRGIL_MULTI_AGENT_PLANNER_CHAIN=google/gemini-2.5-flash-lite,openai/gpt-4o-mini
# VIRGIL_MULTI_AGENT_PLANNER_STAGE_MAX_TOKENS=256,512
# VIRGIL_MULTI_AGENT_PLANNER_MAX_OUTPUT_TOKENS_DEFAULT=384

# Optional lane router (reserved; not implemented)
# VIRGIL_LANE_ROUTER=1

# Reserved: goal-guidance integrations
# VIRGIL_GIT_SIGNALS=1

# Vercel BotID: default logs suspicious POST /api/chat; set to 1 to enforce 403
# BOTID_ENFORCE=1

# Filesystem tool — comma-separated allowed roots (empty = allow all)
ALLOWED_FILE_ROOTS=

# Dev demo seed password (`pnpm db:seed`). Default: virgil-demo
# VIRGIL_SEED_DEMO_PASSWORD=


# =====================================================
# Tier 7 — Evaluation logging
# =====================================================

V2_EVAL_LOGGING=false
V2_TRACE_LOGGING=false
V2_COST_LOGGING=false


# =====================================================
# Tier 8 — Sophon tuning (daily command center)
# =====================================================

# SOPHON_ADAPTIVE_MIN=3
# SOPHON_ADAPTIVE_MAX=7
# SOPHON_STALENESS_GENTLE_DAYS=2
# SOPHON_STALENESS_RESET_DAYS=6
# SOPHON_STALENESS_ACCOUNTABILITY_DAYS=12
