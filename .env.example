# Strongly recommended. For `pnpm dev` only, the app uses an insecure built-in fallback if unset (see lib/auth-secret.ts).
# Required for `next build`, `next start`, and any deploy. Generate: `openssl rand -base64 32`
AUTH_SECRET=****

# Browser origin users actually open (scheme + host + port, no path). NextAuth cookies require an exact match.
# Local: http://localhost:3000  |  LAN: http://192.168.x.x:3000  |  Vercel: https://your-project.vercel.app
# Production / phone access: set both to your real HTTPS URL on Vercel (see docs/vercel-env-setup.md).
AUTH_URL=
NEXT_PUBLIC_APP_URL=

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# Optional: host or LAN Ollama inference server for local-first use.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional: model id for `pnpm warmup:ollama` (defaults to DEFAULT_CHAT_MODEL in lib/ai/models.ts).
# WARMUP_MODEL=ollama/qwen2.5:3b

# optional: disable per-user hourly message cap (local Ollama skips automatically)
# SKIP_CHAT_MESSAGE_RATE_LIMIT=true

# --- GitHub Issues: product opportunities (gateway models only; see docs/github-product-opportunity.md) ---
# GITHUB_REPOSITORY=owner/virgil-repo
# GITHUB_PRODUCT_OPPORTUNITY_TOKEN=ghp_****
# Optional comma-separated labels (defaults in code if unset):
# GITHUB_PRODUCT_OPPORTUNITY_LABELS=product-opportunity,needs-owner-decision

# --- Night review (scheduled job; OpenClaw-style workspace under workspace/night/) ---
# NIGHT_REVIEW_ENABLED=1
# NIGHT_REVIEW_MODEL=ollama/qwen2.5:7b-review
# NIGHT_REVIEW_STAGGER_SECONDS=60
# NIGHT_REVIEW_TIMEZONE=UTC
# Uses existing QSTASH_* keys and CRON_SECRET for /api/night-review/enqueue (see AGENTS.md).
# NIGHT_REVIEW_EMAIL_ON_FINDINGS=1
# AGENT_FETCH_ALLOWLIST_HOSTS=geocoding-api.open-meteo.com,api.open-meteo.com

# Tool: Filesystem — comma-separated allowed root directories (empty = allow all)
ALLOWED_FILE_ROOTS=

# Tool: Jira Cloud integration
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Tool: Google Calendar (future — requires OAuth)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=

# Mem0 Cloud — semantic memory layer (optional, degrades gracefully to Postgres FTS)
# Get your API key at https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=
# Monthly cap on mem0 search (retrieval) API calls; falls back to Postgres FTS when exhausted (default 1000)
# MEM0_MONTHLY_SEARCH_LIMIT=1000
# Optional monthly cap on mem0 add (write) API calls when REDIS_URL is set; omit for unlimited
# MEM0_MONTHLY_ADD_LIMIT=2000
# Skip Mem0 batch ingest after local Ollama turns only (default: local chats sync to Mem0 when MEM0_API_KEY is set)
# MEM0_DISABLE_LOCAL_SYNC=1

# --- Agent task triage (background Ollama job; see AGENTS.md § Agent Task Pickup Convention) ---
# AGENT_TASK_TRIAGE_ENABLED=1
# AGENT_TASK_TRIAGE_MODEL=ollama/qwen2.5:7b-instruct

# Optional gateway-only planner pass before main reply (AutoGen-style; extra cost/latency). Local Ollama path ignores this.
# VIRGIL_MULTI_AGENT_ENABLED=1
# VIRGIL_MULTI_AGENT_PLANNER_MODEL=openai/gpt-4o-mini

# --- Future goal-guidance integrations (default off; reserved for roadmap) ---
# VIRGIL_CALENDAR_INTEGRATION=1
# VIRGIL_GIT_SIGNALS=1
# VIRGIL_JOURNAL_FILE_PARSE=1

# Path to user context file (defaults to ./user-context.md)
# USER_CONTEXT_PATH=

# v2 Evaluation (optional)
V2_EVAL_LOGGING=false

# --- OpenClaw bridge (optional LAN execution gateway; see docs/openclaw-bridge.md) ---
# OPENCLAW_URL derives HTTP origin (ws→http, wss→https). Direct HTTP: use OPENCLAW_HTTP_URL instead.
# OPENCLAW_URL=ws://localhost:3100
# OPENCLAW_HTTP_URL=http://localhost:3100
# OPENCLAW_EXECUTE_PATH=/api/execute
# OPENCLAW_SKILLS_PATH=/api/skills
# OPENCLAW_HEALTH_PATH=/health
