# Strongly recommended. For `pnpm dev` only, the app uses an insecure built-in fallback if unset (see lib/auth-secret.ts).
# Required for `next build`, `next start`, and any deploy. Generate: `openssl rand -base64 32`
AUTH_SECRET=****

# Browser origin users actually open (scheme + host + port, no path). NextAuth cookies require an exact match.
# Local: http://localhost:3000  |  LAN: http://192.168.x.x:3000  |  Vercel: https://your-project.vercel.app
# Production / phone access: set both to your real HTTPS URL on Vercel (see docs/vercel-env-setup.md).
AUTH_URL=
NEXT_PUBLIC_APP_URL=

# Optional: disable passwords — email-only sign-in for allowlisted addresses (trusted / single-owner setups; see AGENTS.md).
# VIRGIL_PASSWORDLESS_LOGIN=1
# VIRGIL_PASSWORDLESS_EMAILS=you@example.com

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Postgres connection string — Neon, Supabase, or any standard Postgres.
# Neon: https://console.neon.tech (pooled/serverless string for Vercel)
# Supabase: https://supabase.com/dashboard — use the **transaction pooler** URI
#   (port 6543) for the app at runtime; use the **direct** connection (port 5432)
#   when running `pnpm db:migrate` if the pooler rejects DDL.
POSTGRES_URL=****

# Optional: plaintext for `pnpm db:seed` demo user `demo@virgil.local` (default `virgil-demo`). Dev database only.
# VIRGIL_SEED_DEMO_PASSWORD=

# https://vercel.com/docs/redis
REDIS_URL=****

# QStash (Upstash Console → QStash → Details): token + signing keys for reminders, night review, agent-task triage.
# QSTASH_TOKEN=ey…
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=
# API base URL must match the QStash **region** for your token (SDK defaults to EU if unset). Multi-region: https://upstash.com/docs/qstash/howto/multi-region
# QSTASH_URL=https://qstash-us-east-1.upstash.io
# QSTASH_URL=https://qstash.upstash.io

# Optional: host or LAN Ollama inference server (picker + optional gateway failure fallback).
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional: model id for `pnpm warmup:ollama` (defaults to DEFAULT_CHAT_MODEL in lib/ai/models.ts).
# WARMUP_MODEL=ollama/qwen2.5:3b

# Default chat model (picker + new chats). Built-in default is `google/gemini-2.5-flash-lite`.
# Prefer NEXT_PUBLIC_DEFAULT_CHAT_MODEL so the Next.js client bundle matches the server.
# NEXT_PUBLIC_DEFAULT_CHAT_MODEL=google/gemini-2.5-flash-lite
# Server-only override (client falls back to built-in default if NEXT_PUBLIC_* is unset):
# DEFAULT_CHAT_MODEL=openai/gpt-oss-20b

# Vercel BotID (see botid package + instrumentation-client.ts): default log suspicious POST /api/chat only; set to enforce 403
# BOTID_ENFORCE=1

# --- GitHub Issues: product opportunities (gateway models only; see docs/github-product-opportunity.md) ---
# GITHUB_REPOSITORY=owner/virgil-repo
# GITHUB_PRODUCT_OPPORTUNITY_TOKEN=ghp_****
# Optional comma-separated labels (defaults in code if unset):
# GITHUB_PRODUCT_OPPORTUNITY_LABELS=product-opportunity,needs-owner-decision

# --- Direct Gemini (personal API key) ---
# Direct Google Generative AI key for Gemini models. Used for:
#   1. Chat fallback (Ollama down → Gemini → AI Gateway) when VIRGIL_CHAT_FALLBACK=1
# Night review and journal parse use local Ollama only (`NIGHT_REVIEW_MODEL=ollama/…`).
# Get a key at https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=

# --- Chat fallback (local → Gemini → Gateway) ---
# When enabled, Ollama failures (unreachable, missing model, timeout) escalate to
# Gemini (if GOOGLE_GENERATIVE_AI_API_KEY set), then Vercel AI Gateway — so chat
# stays available even when local inference is down.
# VIRGIL_CHAT_FALLBACK=1
# VIRGIL_FALLBACK_GEMINI_MODEL=gemini-2.5-flash
# VIRGIL_FALLBACK_GATEWAY_MODEL=google/gemini-2.5-flash-lite

# --- Gateway → Gemini direct → Ollama (hosted path fails pre-stream) ---
# When GOOGLE_GENERATIVE_AI_API_KEY is set, gateway failures (incl. many rate limits) try direct Gemini first.
# Optional override for that Gemini model (bare name, optional gemini/ prefix stripped):
# VIRGIL_GATEWAY_FALLBACK_GEMINI_MODEL=gemini-2.5-flash-lite
# VIRGIL_GATEWAY_FALLBACK_OLLAMA=1
# DEFAULT_GATEWAY_FALLBACK_OLLAMA_MODEL=ollama/qwen2.5:7b-instruct

# --- virgil/auto picker (server picks local vs lite hosted) ---
# VIRGIL_AUTO_LOCAL_MODEL=ollama/qwen2.5:3b
# VIRGIL_AUTO_HOSTED_FALLBACK_MODEL=google/gemini-2.5-flash-lite

# --- Optional lane router (reserved; classifier pass not implemented yet) ---
# VIRGIL_LANE_ROUTER=1

# --- Client: Web Speech TTS (Speak on assistant messages) ---
# NEXT_PUBLIC_VIRGIL_TTS_ENABLED=1

# --- Night review (scheduled job; OpenClaw-style workspace under workspace/night/) ---
# Vercel production: on by default when unset. Local/preview: set NIGHT_REVIEW_ENABLED=1 to run. Use =0 to disable anywhere.
# NIGHT_REVIEW_ENABLED=1
# NIGHT_REVIEW_MODEL=ollama/qwen2.5:7b-review
# Night review uses local Ollama only (no Gemini / Gateway). On Vercel, point OLLAMA_BASE_URL at a reachable host or set NIGHT_REVIEW_ENABLED=0.
# NIGHT_REVIEW_STAGGER_SECONDS=60
# NIGHT_REVIEW_TIMEZONE=America/New_York
# Off-peak local window (default 23:00–07:00, end hour exclusive) + one run hour inside it for heavy work (default 23 = 11:00pm).
# NIGHT_REVIEW_OFF_PEAK_START_HOUR=23
# NIGHT_REVIEW_OFF_PEAK_END_HOUR=7
# NIGHT_REVIEW_RUN_LOCAL_HOUR=23
# Uses existing QSTASH_* keys and CRON_SECRET for /api/night-review/enqueue (see AGENTS.md).
# NIGHT_REVIEW_EMAIL_ON_FINDINGS=1
# AGENT_FETCH_ALLOWLIST_HOSTS=geocoding-api.open-meteo.com,api.open-meteo.com

# Tool: Filesystem — comma-separated allowed root directories (empty = allow all)
ALLOWED_FILE_ROOTS=

# Tool: Jira Cloud integration
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Google Calendar: see block under "Read-only Google Calendar" below (docs/google-calendar-integration.md).

# Mem0 Cloud — semantic memory layer (optional, degrades gracefully to Postgres FTS)
# Get your API key at https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=
# Monthly cap on mem0 search (retrieval) API calls; falls back to Postgres FTS when exhausted (default 1000)
# MEM0_MONTHLY_SEARCH_LIMIT=1000
# Optional monthly cap on mem0 add (write) API calls when REDIS_URL is set; omit for unlimited
# MEM0_MONTHLY_ADD_LIMIT=2000
# Skip Mem0 batch ingest after local Ollama turns only (default: local chats sync to Mem0 when MEM0_API_KEY is set)
# MEM0_DISABLE_LOCAL_SYNC=1

# Postgres memories surfaced in the system prompt (defaults: 30-day window, 80 newest rows; gateway sees all loaded; local slim uses up to 10)
# MEMORY_PROMPT_WINDOW_DAYS=30
# MEMORY_PROMPT_FETCH_LIMIT=80

# --- Agent task triage (background Ollama job; see AGENTS.md § Agent Task Pickup Convention) ---
# AGENT_TASK_TRIAGE_ENABLED=1
# AGENT_TASK_TRIAGE_MODEL=ollama/qwen2.5:7b-instruct

# Optional gateway-only planner pass before main reply (AutoGen-style; extra cost/latency). Local Ollama path ignores this.
# VIRGIL_MULTI_AGENT_ENABLED=1
# VIRGIL_MULTI_AGENT_PLANNER_MODEL=openai/gpt-4o-mini

# --- Read-only Google Calendar (see docs/google-calendar-integration.md + AGENTS.md § 1.10) ---
# VIRGIL_CALENDAR_INTEGRATION=1
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=

# --- Apple Watch / HealthKit ingest (native companion POSTs here; Bearer secret) ---
# VIRGIL_HEALTH_INGEST_ENABLED=1
# VIRGIL_HEALTH_INGEST_SECRET=
# VIRGIL_HEALTH_INGEST_USER_ID=

# --- General context ingest (scripts, shortcuts; Bearer secret → fixed user id) ---
# VIRGIL_INGEST_ENABLED=1
# VIRGIL_INGEST_SECRET=
# VIRGIL_INGEST_USER_ID=

# --- Memory bridge (terminal/scripts: search + save Memory via HTTP; see docs/memory-store-parity.md) ---
# VIRGIL_MEMORY_BRIDGE_ENABLED=1
# VIRGIL_MEMORY_BRIDGE_SECRET=
# VIRGIL_MEMORY_BRIDGE_USER_ID=
# Optional: pnpm memory:bridge target when not local (defaults to NEXT_PUBLIC_APP_URL or http://localhost:3000)
# VIRGIL_MEMORY_BRIDGE_BASE_URL=https://your-deployment.vercel.app

# --- Alexa channel webhook (single-owner voice ingress) ---
# VIRGIL_ALEXA_ENABLED=1
# VIRGIL_ALEXA_SECRET=
# VIRGIL_ALEXA_USER_ID=

# Resend webhook signing secret (Svix) for inbound email → /api/ingest/email
# RESEND_WEBHOOK_SECRET=

# --- Inbound email → Memory (Resend receiving + verified domain; see AGENTS.md) ---
# VIRGIL_EMAIL_INGEST_ENABLED=1
# VIRGIL_EMAIL_INGEST_ALLOWED_FROM=you@yourdomain.com

# --- Future goal-guidance integrations (default off; reserved for roadmap) ---
# VIRGIL_GIT_SIGNALS=1

# --- Journal file parse (cron or POST body; uses NIGHT_REVIEW_MODEL stack) ---
# VIRGIL_JOURNAL_FILE_PARSE=1
# VIRGIL_JOURNAL_FILE_PATH=workspace/journal/today.md

# Optional: override path to user context markdown (default: workspace/user-context.md)
# Legacy repo-root file: USER_CONTEXT_PATH=./user-context.md
# USER_CONTEXT_PATH=

# v2 Evaluation (optional)
V2_EVAL_LOGGING=false
# Optional: decision-trace JSONL at workspace/v2-eval/traces.jsonl
V2_TRACE_LOGGING=false
# Optional: gateway/gemini token usage JSONL at workspace/v2-eval/costs.jsonl
V2_COST_LOGGING=false

# Ollama embeddings for Memory (pgvector; uses OLLAMA_BASE_URL). See AGENTS.md.
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768

# --- OpenClaw bridge (optional LAN execution gateway; see docs/openclaw-bridge.md) ---
# OPENCLAW_URL derives HTTP origin (ws→http, wss→https). Direct HTTP: use OPENCLAW_HTTP_URL instead.
# For hardened LAN setups, prefer an SSH tunnel and point these to localhost (example: 127.0.0.1:13100).
# See docs/openclaw-ssh-tunnel-hardening.md.
# OPENCLAW_URL=ws://127.0.0.1:13100
# OPENCLAW_HTTP_URL=http://127.0.0.1:13100
# OPENCLAW_EXECUTE_PATH=/api/execute
# OpenClaw Gateway (current): use POST /tools/invoke — not /v1/execute (different body).
# OPENCLAW_EXECUTE_PATH=/tools/invoke
# OPENCLAW_GATEWAY_TOOLS_INVOKE=1
# OPENCLAW_GATEWAY_TOKEN=   # Bearer; matches gateway auth (see OpenClaw docs)
# OPENCLAW_SKILLS_PATH=/api/skills
# If GET returns HTML (Control UI), list tool names for Hermes bridge merge:
# OPENCLAW_EXTRA_SKILL_NAMES=sessions_list,web_fetch
# OPENCLAW_HEALTH_PATH=/health

# --- Delegation backend bridge (Virgil 1.1) ---
# Selects delegation provider path in-app.
# Default when unset: prefer Hermes when configured, else OpenClaw (see docs/virgil-manos-delegation.md).
#
# Vercel Production (phone / any PC → manos): tunnel Hermes only; do not set OPENCLAW_* or OLLAMA_BASE_URL.
# See docs/virgil-manos-delegation.md — "Vercel production: Cloudflare Tunnel to Hermes only".
# HERMES_HTTP_URL=https://hermes.<your-domain>
# HERMES_SHARED_SECRET=<same as Hermes on manos>
# VIRGIL_DELEGATION_BACKEND=hermes
#
# When BOTH Hermes and OpenClaw URLs are set, failover to the other gateway if primary ping fails (default on).
# VIRGIL_DELEGATION_FAILOVER=1
# Optional Hermes bridge endpoint (when delegation backend is hermes).
# HERMES_HTTP_URL=http://127.0.0.1:8765
# HERMES_EXECUTE_PATH=/api/execute
# HERMES_PENDING_PATH=/api/pending
# HERMES_SKILLS_PATH=/api/skills
# HERMES_HEALTH_PATH=/health
# Optional shared bearer for non-local Hermes deployments.
# HERMES_SHARED_SECRET=
# Local dev helper: enable built-in Hermes bridge stub routes in this app
# (`/api/hermes/health`, `/api/hermes/execute`, `/api/hermes/pending`) and
# point HERMES_*_PATH to those routes when no external Hermes HTTP bridge runs.
# VIRGIL_HERMES_BRIDGE_STUB_ENABLED=1

# --- Hermes local bridge (real process; `pnpm hermes:local-bridge` — scripts/hermes-local-bridge.ts) ---
# Disable the in-app stub above, then point Virgil at loopback Hermes defaults:
# VIRGIL_HERMES_BRIDGE_STUB_ENABLED=0
# HERMES_HTTP_URL=http://127.0.0.1:8765
# HERMES_EXECUTE_PATH=/api/execute
# HERMES_PENDING_PATH=/api/pending
# HERMES_SKILLS_PATH=/api/skills
# HERMES_HEALTH_PATH=/health
# Optional: HERMES_SHARED_SECRET= (must match bridge if set)
# OPENCLAW_* below is read by the bridge to forward /api/execute to your LAN gateway.
# HERMES_LOCAL_BRIDGE_PORT=8765

# Synchronous embeddings via delegation (chat tool embedViaDelegation; see docs/openclaw-bridge.md)
# VIRGIL_DELEGATION_EMBED_SKILL=wiki-embed
# VIRGIL_DELEGATION_EMBED_TIMEOUT_MS=30000
# VIRGIL_DELEGATION_EMBED_ENABLED=1

# --- Virgil 1.1 wiki ops (manual admin trigger; disabled by default) ---
# Enables POST /api/wiki/ops with Authorization: Bearer $CRON_SECRET
# VIRGIL_WIKI_OPS_ENABLED=1
# Optional wiki root path override (defaults to workspace/wiki-starter)
# VIRGIL_WIKI_ROOT=workspace/wiki-starter
# Enables GET /api/wiki/daily with Authorization: Bearer $CRON_SECRET
# VIRGIL_WIKI_DAILY_ENABLED=1

# --- Daily digest → Slack mirror (optional; same text as email; see docs/operator-integrations-runbook.md) ---
# Prefer incoming webhook (simplest):
# VIRGIL_SLACK_CHECKIN_WEBHOOK_URL=https://hooks.slack.com/services/...
# Or Bot token + channel (chat.postMessage):
# SLACK_BOT_TOKEN=xoxb-...
# VIRGIL_SLACK_CHECKIN_CHANNEL_ID=C01234567890

# --- Digital Self orchestrator (optional; sibling package in digital-self/; see docs/digital-self-bridge.md) ---
# DIGITAL_SELF_BASE_URL=http://127.0.0.1:8790
# DIGITAL_SELF_SERVICE_TOKEN=
# Shared bearer for orchestrator → Virgil callbacks (POST /api/digital-self/webhook); must match digital-self VIRGIL_BRIDGE_WEBHOOK_SECRET.
# VIRGIL_BRIDGE_WEBHOOK_SECRET=

# --- Sophon daily command center tuning (Option B v1) ---
# SOPHON_ADAPTIVE_MIN=3
# SOPHON_ADAPTIVE_MAX=7
# SOPHON_STALENESS_GENTLE_DAYS=2
# SOPHON_STALENESS_RESET_DAYS=6
# SOPHON_STALENESS_ACCOUNTABILITY_DAYS=12
