{
  "name": "virgil-digital-self",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "cd .. && pnpm exec biome check digital-self",
    "fix": "cd .. && pnpm exec biome check --write digital-self",
    "type-check": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.5",
    "hono": "^4.12.12",
    "nanoid": "^5.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.32.1"
}
