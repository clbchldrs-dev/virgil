# Copy to `.env.docker` (gitignored) for `docker compose up --build`.
# Postgres and Redis URLs are set inside docker-compose.yml; do not duplicate them here unless you customize the stack.

# LAN / other devices: set AUTH_URL and NEXT_PUBLIC_APP_URL to http://<server-lan-ip>:3000 (same origin as the browser).
# Either add them to a project-root `.env` (Compose loads it for substitution) or uncomment below and run:
#   docker compose --env-file .env.docker up --build
# AUTH_URL=http://192.168.1.50:3000
# NEXT_PUBLIC_APP_URL=http://192.168.1.50:3000

# Required for production Next.js / Auth.js inside the container (generate: openssl rand -base64 32)
AUTH_SECRET=

# Optional: override cookie security (docker-compose sets AUTH_URL=http://localhost:3000 for HTTP).
# AUTH_COOKIE_SECURE=false

# Same keys as `.env.local` / AGENTS.md — needed for cloud models, uploads, etc.
AI_GATEWAY_API_KEY=
BLOB_READ_WRITE_TOKEN=

# Ollama: default in docker-compose.yml is the bundled `ollama` service (reachable as http://ollama:11434 from virgil-app).
# Override only if you use host Ollama or docker-compose.host-ollama.yml, e.g.:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional: `pnpm warmup:ollama` from the host (see AGENTS.md) — defaults to DEFAULT_CHAT_MODEL if unset.
# WARMUP_MODEL=ollama/qwen2.5:3b

# Optional Mem0 (see AGENTS.md): MEM0_API_KEY, MEM0_MONTHLY_SEARCH_LIMIT, MEM0_MONTHLY_ADD_LIMIT, MEM0_DISABLE_LOCAL_SYNC=1, MEMORY_PROMPT_WINDOW_DAYS, MEMORY_PROMPT_FETCH_LIMIT

# Optional extras (see AGENTS.md): QSTASH_*, RESEND_API_KEY, CRON_SECRET, NIGHT_REVIEW_* etc.
# Optional gateway planner+executor (see lib/ai/orchestration/): VIRGIL_MULTI_AGENT_ENABLED=1, VIRGIL_MULTI_AGENT_PLANNER_MODEL=…
